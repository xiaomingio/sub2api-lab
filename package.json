{
  "name": "sub2api-lab",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "npm run build:client && NODE_ENV=development node --env-file=.env.development ./node_modules/tsx/dist/cli.mjs watch src/server.ts",
    "build": "npm run build:client && tsc",
    "build:client": "vite build",
    "start": "NODE_ENV=development node --env-file=.env.development dist/server.js",
    "typecheck": "tsc --noEmit && tsc -p tsconfig.test.json && tsc -p tsconfig.client.json",
    "test": "node --import tsx --test tests/*.test.ts",
    "deploy:validate": "tinyship validate",
    "deploy:preflight": "tinyship preflight",
    "deploy:all": "tinyship deploy all",
    "deploy:sub2api-lab": "tinyship deploy service sub2api-lab",
    "deploy:dry-run": "tinyship dry-run all",
    "deploy": "tinyship deploy all"
  },
  "dependencies": {
    "@fastify/static": "^9.1.3",
    "fastify": "^5.2.1",
    "pg": "^8.13.1",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "@types/pg": "^8.11.10",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "@xiaomingio/tinyship": "^0.1.8",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vite": "^8.1.5"
  }
}
